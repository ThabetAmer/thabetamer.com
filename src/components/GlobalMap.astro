---
import { getMapMarkers } from '../data/work';
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const mapMarkers = getMapMarkers();
---

<section class="py-12 mb-20 animate-on-scroll" id="global-reach">
  <h2 class="text-section-heading text-sm font-medium uppercase tracking-wider mb-8">
    {t(lang, 'globalReach.title')}
  </h2>

  <div class="relative w-full">
    <!-- Map Container -->
    <div class="map-container relative overflow-visible">
      <!-- World Map Image -->
      <object
        data="/images/world-map.svg"
        type="image/svg+xml"
        class="world-map-image w-full h-auto"
        aria-label="World Map"
      >
        <img src="/images/world-map.svg" alt="World Map" />
      </object>

      <!-- SVG Overlay for markers -->
      <svg
        viewBox="0 0 895.92 471.76"
        class="absolute inset-0 w-full h-full pointer-events-none"
        preserveAspectRatio="xMidYMid meet"
        xmlns="http://www.w3.org/2000/svg"
      >
        <!-- Location Markers -->
        {mapMarkers.map((marker) => (
          <g
            class="map-marker cursor-pointer pointer-events-auto"
            data-location-id={marker.location.id}
            data-country={marker.location.country[lang]}
            data-clients={JSON.stringify(marker.projects.map(p => ({
              name: p.client[lang],
              project: p.title[lang]
            })))}
          >
            <!-- Pulse animation ring -->
            <circle
              cx={marker.location.coordinates.x}
              cy={marker.location.coordinates.y}
              r="8"
              class="fill-none stroke-primary/40 marker-pulse"
              stroke-width="2"
            />
            <!-- Main marker dot -->
            <circle
              cx={marker.location.coordinates.x}
              cy={marker.location.coordinates.y}
              r="4"
              class="fill-primary marker-dot transition-all duration-300"
            />
          </g>
        ))}
      </svg>

      <!-- Tooltip -->
      <div
        id="map-tooltip"
        class="absolute pointer-events-none opacity-0 transition-opacity duration-200 z-10"
        style="transform: translate(-50%, -100%);"
      >
        <div class="bg-card border border-border rounded-lg shadow-lg p-3 min-w-[180px] max-w-[240px]">
          <h4 id="tooltip-country" class="text-sm font-medium text-foreground mb-2"></h4>
          <div id="tooltip-clients" class="space-y-1.5"></div>
        </div>
        <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[6px] border-t-border mx-auto -mt-px"></div>
      </div>
    </div>

  </div>
</section>

<style>
  .map-container {
    aspect-ratio: 895.92 / 471.76;
  }

  .world-map-image {
    opacity: 0.85;
  }

  :global(.dark) .world-map-image {
    opacity: 0.9;
  }

  @keyframes pulse-ring {
    0% {
      r: 4;
      opacity: 1;
    }
    100% {
      r: 14;
      opacity: 0;
    }
  }

  .marker-pulse {
    animation: pulse-ring 2s ease-out infinite;
  }

  .map-marker:hover .marker-dot {
    r: 6;
  }

  .map-marker:hover .marker-pulse {
    animation-duration: 1s;
  }
</style>

<script>
  function initMapInteraction() {
    const markers = document.querySelectorAll('.map-marker');
    const tooltip = document.getElementById('map-tooltip');
    const tooltipCountry = document.getElementById('tooltip-country');
    const tooltipClients = document.getElementById('tooltip-clients');
    const mapContainer = document.querySelector('.map-container');

    if (!tooltip || !tooltipCountry || !tooltipClients || !mapContainer) return;

    markers.forEach((marker) => {
      marker.addEventListener('mouseenter', (e) => {
        const target = e.currentTarget as SVGGElement;
        const country = target.dataset.country || '';
        const clients = JSON.parse(target.dataset.clients || '[]') as { name: string; project: string }[];

        // Get marker position
        const circle = target.querySelector('.marker-dot') as SVGCircleElement;
        if (!circle) return;

        const svg = circle.ownerSVGElement;
        if (!svg) return;

        const svgRect = svg.getBoundingClientRect();
        const containerRect = mapContainer.getBoundingClientRect();

        // Get the circle's position in SVG coordinates
        const cx = parseFloat(circle.getAttribute('cx') || '0');
        const cy = parseFloat(circle.getAttribute('cy') || '0');

        // Convert SVG coordinates to screen coordinates
        const viewBox = svg.viewBox.baseVal;
        const scaleX = svgRect.width / viewBox.width;
        const scaleY = svgRect.height / viewBox.height;

        const screenX = cx * scaleX + (svgRect.left - containerRect.left);
        const screenY = cy * scaleY + (svgRect.top - containerRect.top);

        // Update tooltip content
        tooltipCountry.textContent = country;
        tooltipClients.innerHTML = clients.map(client => `
          <div class="text-xs">
            <span class="text-muted-foreground">${client.name}</span>
            <span class="block text-foreground/70">${client.project}</span>
          </div>
        `).join('');

        // Position tooltip
        tooltip.style.left = `${screenX}px`;
        tooltip.style.top = `${screenY - 10}px`;
        tooltip.classList.remove('opacity-0');
        tooltip.classList.add('opacity-100');
      });

      marker.addEventListener('mouseleave', () => {
        tooltip.classList.remove('opacity-100');
        tooltip.classList.add('opacity-0');
      });
    });
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initMapInteraction);

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initMapInteraction);
</script>
