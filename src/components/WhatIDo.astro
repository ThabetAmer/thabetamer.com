---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import { services } from '../data/services';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="what-i-do" class="mb-20 animate-on-scroll">
  <h2 class="text-sm font-medium tracking-widest text-section-heading uppercase mb-6">
    {t(lang, 'whatIDo.title')}
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {services.map((service, index) => (
      <div
        class="p-5 rounded-xl border border-border bg-secondary/30 hover:bg-secondary/50 transition-colors duration-200 animate-on-scroll"
        style={`animation-delay: ${index * 75}ms`}
      >
        <Icon name={service.icon as any} class="w-5 h-5 text-muted-foreground mb-3" />
        <h3 class="text-base font-medium text-foreground mb-2">
          {service.title[lang]}
        </h3>
        <p class="text-sm text-muted-foreground leading-relaxed">
          {service.description[lang]}
        </p>
      </div>
    ))}
  </div>
</section>
