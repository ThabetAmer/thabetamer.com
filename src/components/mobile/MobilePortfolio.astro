---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import { getPortfolioProjects, getAllPortfolioTags, type ProjectTag } from '../../data/work';
import ProjectCard from '../ProjectCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const projects = getPortfolioProjects();
const tags = getAllPortfolioTags();

const tagLabels: Record<ProjectTag, string> = {
  product: t(lang, 'portfolio.filters.product'),
  architecture: t(lang, 'portfolio.filters.architecture'),
  cloud: t(lang, 'portfolio.filters.cloud'),
  ai: t(lang, 'portfolio.filters.ai'),
  gov: t(lang, 'portfolio.filters.gov'),
  startups: t(lang, 'portfolio.filters.startups'),
  devops: 'DevOps',
  saas: 'SaaS',
  edtech: 'EdTech',
  ict4d: 'ICT4D',
  agritech: 'AgriTech',
};
---

<section id="m-portfolio" class="mb-8">
  <h2 class="text-xs font-medium tracking-widest text-section-heading uppercase mb-5">
    {t(lang, 'portfolio.title')}
  </h2>

  <!-- Filter pills (horizontal scroll) -->
  <div class="-mx-4 px-4 mb-5">
    <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-none" role="tablist" aria-label="Filter projects">
      {tags.map((tag, index) => (
        <button
          type="button"
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          data-filter={tag}
          class:list={[
            'mobile-filter-pill flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium border transition-all duration-200 ease-out',
            index === 0
              ? 'bg-foreground text-background border-foreground'
              : 'bg-transparent text-muted-foreground border-border hover:border-foreground hover:text-foreground hover:bg-muted',
          ]}
        >
          {tagLabels[tag]}
        </button>
      ))}
    </div>
  </div>

  <!-- Project cards -->
  <div id="mobile-portfolio-section" class="grid grid-cols-1 gap-5">
    {projects.map((project, index) => (
      <ProjectCard project={project} lang={lang} index={index} />
    ))}
  </div>
</section>

<!-- Mobile Project Lightbox -->
<div
  id="m-project-lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-background/80 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="m-project-lightbox-title"
>
  <div class="relative max-w-sm w-full max-h-[90vh] overflow-y-auto bg-card rounded-xl shadow-2xl border border-border">
    <button
      type="button"
      id="m-project-lightbox-close"
      class="absolute top-3 end-3 z-10 p-2 rounded-lg bg-muted/80 text-muted-foreground hover:text-foreground transition-colors"
      aria-label="Close preview"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="aspect-video bg-muted">
      <img id="m-project-lightbox-image" src="" alt="" class="w-full h-full object-cover" />
    </div>

    <div class="p-5">
      <p id="m-project-lightbox-title" class="text-xl font-semibold text-foreground mb-2"></p>
      <p id="m-project-lightbox-meta" class="text-sm text-muted-foreground mb-3"></p>
      <span id="m-project-lightbox-role" class="inline-block px-3 py-1 text-sm font-medium rounded-full bg-muted text-muted-foreground mb-3"></span>
      <p id="m-project-lightbox-description" class="text-sm text-muted-foreground leading-relaxed mb-3"></p>
      <div id="m-project-lightbox-details" class="text-sm text-muted-foreground leading-relaxed mb-3 pt-3 border-t border-border hidden"></div>
      <p id="m-project-lightbox-tags" class="text-xs text-muted-foreground/70"></p>
    </div>
  </div>
</div>

<script>
  let _mobileFilterCleanups: (() => void)[] = [];
  const _mobileHideTimeouts = new Map<string, number>();

  function initMobileFilters() {
    _mobileFilterCleanups.forEach((fn) => fn());
    _mobileFilterCleanups = [];
    _mobileHideTimeouts.forEach((id) => clearTimeout(id));
    _mobileHideTimeouts.clear();

    const section = document.getElementById('mobile-portfolio-section');
    if (!section) return;

    const pills = document.querySelectorAll<HTMLElement>('.mobile-filter-pill');
    const cards = section.querySelectorAll<HTMLElement>('.project-card');

    // Reset all mobile cards (override any global filter state)
    cards.forEach((card) => {
      card.style.display = 'block';
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    });

    // Apply initial filter from first pill
    const firstPill = pills[0];
    if (firstPill) {
      const initialTag = firstPill.getAttribute('data-filter');
      mobileFilterCards(initialTag, cards, true);
    }

    pills.forEach((pill) => {
      const handleClick = () => {
        const tag = pill.getAttribute('data-filter');

        pills.forEach((p) => {
          p.classList.remove('bg-foreground', 'text-background', 'border-foreground');
          p.classList.add('bg-transparent', 'text-muted-foreground', 'border-border');
          p.setAttribute('aria-selected', 'false');
        });
        pill.classList.remove('bg-transparent', 'text-muted-foreground', 'border-border');
        pill.classList.add('bg-foreground', 'text-background', 'border-foreground');
        pill.setAttribute('aria-selected', 'true');

        mobileFilterCards(tag, cards, false);
      };
      pill.addEventListener('click', handleClick);
      _mobileFilterCleanups.push(() => pill.removeEventListener('click', handleClick));
    });
  }

  function mobileFilterCards(
    tag: string | null,
    cards: NodeListOf<HTMLElement>,
    immediate: boolean,
  ) {
    _mobileHideTimeouts.forEach((id) => clearTimeout(id));
    _mobileHideTimeouts.clear();

    let visibleIndex = 0;
    cards.forEach((card) => {
      const cardId = card.getAttribute('data-project-id') || '';
      const cardTags = card.getAttribute('data-tags')?.split(',') || [];
      const shouldShow = cardTags.includes(tag || '');

      if (shouldShow) {
        if (immediate) {
          card.style.display = 'block';
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        } else {
          const delay = visibleIndex * 75;
          card.style.display = 'block';
          requestAnimationFrame(() => {
            setTimeout(() => {
              card.style.opacity = '1';
              card.style.transform = 'translateY(0)';
            }, delay);
          });
        }
        visibleIndex++;
      } else {
        if (immediate) {
          card.style.display = 'none';
          card.style.opacity = '0';
          card.style.transform = 'translateY(8px)';
        } else {
          card.style.opacity = '0';
          card.style.transform = 'translateY(8px)';
          const timeoutId = setTimeout(() => {
            card.style.display = 'none';
            _mobileHideTimeouts.delete(cardId);
          }, 300) as unknown as number;
          _mobileHideTimeouts.set(cardId, timeoutId);
        }
      }
    });
  }

  // Use rAF to run after desktop FilterBar's synchronous init
  requestAnimationFrame(initMobileFilters);
  document.addEventListener('astro:after-swap', () => requestAnimationFrame(initMobileFilters));

  // Mobile project lightbox
  let _mProjectLightboxCleanups: (() => void)[] = [];

  function initMobileProjectLightbox() {
    _mProjectLightboxCleanups.forEach(fn => fn());
    _mProjectLightboxCleanups = [];

    const lightbox = document.getElementById('m-project-lightbox');
    const image = document.getElementById('m-project-lightbox-image') as HTMLImageElement;
    const title = document.getElementById('m-project-lightbox-title');
    const meta = document.getElementById('m-project-lightbox-meta');
    const role = document.getElementById('m-project-lightbox-role');
    const description = document.getElementById('m-project-lightbox-description');
    const details = document.getElementById('m-project-lightbox-details');
    const tags = document.getElementById('m-project-lightbox-tags');
    const closeBtn = document.getElementById('m-project-lightbox-close');
    const section = document.getElementById('m-portfolio');

    if (!lightbox || !image || !title || !closeBtn || !section) return;

    function closeLightbox() {
      lightbox!.classList.add('hidden');
      lightbox!.classList.remove('flex');
      document.body.style.overflow = '';
    }

    const handleCardClick = (e: Event) => {
      const card = (e.target as Element).closest('.project-card');
      if (!card) return;
      image.src = card.getAttribute('data-image') || '';
      image.alt = card.getAttribute('data-title') || '';
      if (title) title.textContent = card.getAttribute('data-title') || '';
      if (meta) meta.textContent = `${card.getAttribute('data-client') || ''} · ${card.getAttribute('data-year') || ''}`;
      if (role) role.textContent = card.getAttribute('data-role') || '';
      if (description) description.textContent = card.getAttribute('data-description') || '';
      const detailText = card.getAttribute('data-details') || '';
      if (details) {
        details.textContent = detailText;
        details.classList.toggle('hidden', !detailText);
      }
      if (tags) tags.textContent = card.getAttribute('data-tags-display') || '';
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };

    section.addEventListener('click', handleCardClick);
    _mProjectLightboxCleanups.push(() => section.removeEventListener('click', handleCardClick));

    closeBtn.addEventListener('click', closeLightbox);
    _mProjectLightboxCleanups.push(() => closeBtn.removeEventListener('click', closeLightbox));

    const handleBackdrop = (e: Event) => { if (e.target === lightbox) closeLightbox(); };
    lightbox.addEventListener('click', handleBackdrop);
    _mProjectLightboxCleanups.push(() => lightbox.removeEventListener('click', handleBackdrop));

    const handleEscape = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) closeLightbox();
    };
    document.addEventListener('keydown', handleEscape);
    _mProjectLightboxCleanups.push(() => document.removeEventListener('keydown', handleEscape));
  }

  initMobileProjectLightbox();
  document.addEventListener('astro:after-swap', initMobileProjectLightbox);
</script>
