---
import { Image } from 'astro:assets';
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import { certifications, education } from '../../data/credentials';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const themeImages: Record<string, { light: string; dark: string }> = {
  '/images/credentials/linkedin-learning.png': {
    light: '/images/credentials/linkedin-learning.png',
    dark: '/images/credentials/linkedin-dark.svg',
  },
  '/images/credentials/birzeit.svg': {
    light: '/images/credentials/birzeit.svg',
    dark: '/images/credentials/birzeit-dark.svg',
  },
};

function hasThemeVariants(imagePath: string): boolean {
  return imagePath in themeImages;
}

function getThemeImages(imagePath: string) {
  return themeImages[imagePath] || { light: imagePath, dark: imagePath };
}
---

<section id="m-credentials" class="mb-8 animate-on-scroll">
  <h2 class="text-xs font-medium tracking-widest text-section-heading uppercase mb-5">
    {t(lang, 'credentials.title')}
  </h2>

  <div class="space-y-8">
    <!-- Certifications -->
    <div>
      <h3 class="text-sm font-medium text-foreground mb-4">
        {t(lang, 'credentials.certifications')}
      </h3>
      <div class="space-y-4">
        {certifications.map((cert, index) => (
          <div class="flex gap-3 animate-on-scroll" style={`animation-delay: ${index * 60}ms`}>
            <button
              type="button"
              class="credential-preview-btn w-14 h-14 rounded-lg overflow-hidden flex-shrink-0
                     cursor-pointer hover:ring-2 hover:ring-ring transition-all bg-muted"
              data-image={cert.image}
              data-title={cert.name[lang]}
              aria-label={`View ${cert.name[lang]} certificate`}
            >
              {hasThemeVariants(cert.image) ? (
                <>
                  <Image
                    src={getThemeImages(cert.image).light}
                    alt={cert.issuer[lang]}
                    class="w-full h-full object-contain dark:hidden"
                    width={56}
                    height={56}
                  />
                  <Image
                    src={getThemeImages(cert.image).dark}
                    alt={cert.issuer[lang]}
                    class="w-full h-full object-contain hidden dark:block"
                    width={56}
                    height={56}
                  />
                </>
              ) : (
                <Image
                  src={cert.image}
                  alt={cert.issuer[lang]}
                  class="w-full h-full object-contain"
                  width={56}
                  height={56}
                  loading="lazy"
                  decoding="async"
                />
              )}
            </button>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2">
                <button
                  type="button"
                  class="credential-preview-btn text-sm font-medium text-foreground text-start
                         hover:text-muted-foreground transition-colors cursor-pointer leading-snug"
                  data-image={cert.image}
                  data-title={cert.name[lang]}
                >
                  {cert.name[lang]}
                </button>
                <span class="text-xs text-muted-foreground font-mono flex-shrink-0">{cert.year}</span>
              </div>
              <p class="text-xs text-muted-foreground mt-0.5">{cert.issuer[lang]}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div>
      <h3 class="text-sm font-medium text-foreground mb-4">
        {t(lang, 'credentials.education')}
      </h3>
      <div class="divide-y divide-border">
        {education.map((edu, index) => (
          <div class="py-4 first:pt-0 last:pb-0 flex gap-3 animate-on-scroll" style={`animation-delay: ${(index + certifications.length) * 60}ms`}>
            <button
              type="button"
              class="credential-preview-btn w-14 h-14 rounded-lg overflow-hidden flex-shrink-0
                     cursor-pointer hover:ring-2 hover:ring-ring transition-all bg-muted"
              data-image={edu.image}
              data-title={edu.institution[lang]}
              aria-label={`View ${edu.institution[lang]}`}
            >
              {hasThemeVariants(edu.image) ? (
                <>
                  <Image
                    src={getThemeImages(edu.image).light}
                    alt={edu.institution[lang]}
                    class="w-full h-full object-contain dark:hidden"
                    width={56}
                    height={56}
                  />
                  <Image
                    src={getThemeImages(edu.image).dark}
                    alt={edu.institution[lang]}
                    class="w-full h-full object-contain hidden dark:block"
                    width={56}
                    height={56}
                  />
                </>
              ) : (
                <Image
                  src={edu.image}
                  alt={edu.institution[lang]}
                  class="w-full h-full object-contain"
                  width={56}
                  height={56}
                  loading="lazy"
                  decoding="async"
                />
              )}
            </button>
            <div class="flex-1 min-w-0">
              <button
                type="button"
                class="credential-preview-btn text-sm font-medium text-foreground text-start
                       hover:text-muted-foreground transition-colors cursor-pointer block leading-snug"
                data-image={edu.image}
                data-title={edu.institution[lang]}
              >
                {edu.degree[lang]}
              </button>
              <p class="text-xs text-muted-foreground mt-0.5">
                {edu.institution[lang]}
                {edu.field && ` — ${edu.field[lang]}`}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
