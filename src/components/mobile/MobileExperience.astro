---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import { experiences } from '../../data/experience';
import Icon from '../Icon.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const typeIcons = {
  leadership: 'rocket',
  technical: 'code',
  hybrid: 'target',
  founder: 'heartbeat',
} as const;
---

<section id="m-experience" class="mb-8 animate-on-scroll">
  <h2 class="text-xs font-medium tracking-widest text-section-heading uppercase mb-5">
    {t(lang, 'experience.title')}
  </h2>

  <div class="relative">
    <!-- Timeline line -->
    <div class="absolute start-[11px] top-2 bottom-2 w-px bg-border"></div>

    <div class="space-y-0">
      {experiences.map((exp, index) => (
        <div
          class="relative flex gap-4 py-3 group animate-on-scroll"
          style={`--delay: ${index * 60}ms`}
        >
          <!-- Node -->
          <div class="relative z-10 flex-shrink-0">
            <div
              class={`w-6 h-6 rounded-full flex items-center justify-center transition-colors
                ${exp.highlight
                  ? 'bg-foreground text-background'
                  : 'bg-secondary border border-border group-hover:border-muted-foreground'
                }`}
            >
              <Icon name={typeIcons[exp.type]} class="w-2.5 h-2.5" />
            </div>
          </div>

          <!-- Content -->
          <div class="flex-1 min-w-0 flex items-start justify-between gap-2 pb-0.5">
            <div class="min-w-0">
              <h3 class={`text-sm font-medium leading-snug ${exp.highlight ? 'text-foreground' : 'text-foreground/80'}`}>
                {exp.title[lang]}
              </h3>
              <p class="text-xs text-muted-foreground mt-0.5">
                {exp.company[lang]}
              </p>
            </div>
            <span class="text-xs text-muted-foreground font-mono flex-shrink-0 mt-0.5">
              {exp.period}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
