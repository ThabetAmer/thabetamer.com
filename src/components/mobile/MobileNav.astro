---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const navItems = [
  { label: t(lang, 'nav.portfolio'), href: '#m-portfolio' },
  { label: t(lang, 'nav.services'), href: '#m-services' },
  { label: t(lang, 'experience.title'), href: '#m-experience' },
  { label: t(lang, 'nav.credentials'), href: '#m-credentials' },
  { label: t(lang, 'nav.writing'), href: '#m-writing' },
  { label: t(lang, 'nav.contact'), href: '#m-contact', primary: true },
];
---

<nav class="mb-8" aria-label="Page sections">
  <div class="flex flex-wrap gap-2">
    {navItems.map((item) => (
      item.primary ? (
        <a
          href={item.href}
          class="cta-shine inline-flex items-center justify-center px-4 py-2 rounded-full
                 border border-foreground bg-foreground text-xs font-medium text-background
                 hover:bg-foreground/90 transition-colors duration-200"
        >
          {item.label}
        </a>
      ) : (
        <a
          href={item.href}
          class="inline-flex items-center justify-center px-4 py-2 rounded-full border border-border
                 text-xs font-medium text-muted-foreground hover:text-foreground
                 hover:border-foreground/50 hover:bg-secondary/30 transition-colors duration-200"
        >
          {item.label}
        </a>
      )
    ))}
  </div>
</nav>
