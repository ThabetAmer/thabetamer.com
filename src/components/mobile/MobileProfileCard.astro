---
import { Image } from 'astro:assets';
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import LanguageToggle from '../LanguageToggle.astro';
import Counter from '../Counter.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="m-hero" class="pt-4 pb-6">
  <!-- Top bar -->
  <div class="flex justify-between items-center mb-7">
    <LanguageToggle currentLang={lang} />
    <button
      id="mobile-theme-toggle"
      type="button"
      class="p-2 rounded-lg text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors duration-200"
      aria-label="Toggle theme"
    >
      <!-- Sun icon (dark mode) -->
      <svg class="hidden dark:block w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2"></path><path d="M12 20v2"></path>
        <path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path>
        <path d="M2 12h2"></path><path d="M20 12h2"></path>
        <path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
      </svg>
      <!-- Moon icon (light mode) -->
      <svg class="block dark:hidden w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
      </svg>
    </button>
  </div>

  <!-- Avatar + identity -->
  <div class="flex flex-col items-center gap-3 mb-6">
    <div class="w-28 h-28 rounded-full overflow-hidden border-2 border-border bg-secondary flex-shrink-0">
      <Image
        src="/images/profile.png"
        alt={t(lang, 'hero.name')}
        class="w-full h-full object-cover object-center dark:invert dark:brightness-50"
        width={112}
        height={112}
        loading="eager"
      />
    </div>

    <div class="text-center space-y-1.5">
      <h1 class="text-2xl font-semibold text-foreground leading-tight">
        {t(lang, 'hero.name')}
      </h1>
      <p class="text-sm text-muted-foreground leading-snug">
        {t(lang, 'hero.tagline')}
      </p>
    </div>

    <p class="text-sm text-muted-foreground text-center leading-relaxed max-w-sm">
      {t(lang, 'hero.bio')}
    </p>
  </div>

  <!-- Stats counters -->
  <div class="grid grid-cols-3 gap-2 border border-border rounded-xl p-4 bg-secondary/20">
    <Counter
      value={t(lang, 'hero.counters.experience.value')}
      label={t(lang, 'hero.counters.experience.label')}
    />
    <Counter
      value={t(lang, 'hero.counters.countries.value')}
      label={t(lang, 'hero.counters.countries.label')}
    />
    <Counter
      value={t(lang, 'hero.counters.projects.value')}
      label={t(lang, 'hero.counters.projects.label')}
    />
  </div>
</section>

<script>
  let _mobileThemeCleanup: (() => void) | null = null;

  function initMobileThemeToggle() {
    if (_mobileThemeCleanup) {
      _mobileThemeCleanup();
      _mobileThemeCleanup = null;
    }

    const btn = document.getElementById('mobile-theme-toggle');
    if (!btn) return;

    const handleClick = () => {
      document.documentElement.classList.add('theme-transition');
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      setTimeout(() => {
        document.documentElement.classList.remove('theme-transition');
      }, 300);
    };

    btn.addEventListener('click', handleClick);
    _mobileThemeCleanup = () => btn.removeEventListener('click', handleClick);
  }

  initMobileThemeToggle();
  document.addEventListener('astro:after-swap', initMobileThemeToggle);
</script>
