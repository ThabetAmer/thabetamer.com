---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import { certifications, education } from '../data/credentials';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Images that have theme-specific versions (light/dark)
const themeImages: Record<string, { light: string; dark: string }> = {
  '/images/credentials/linkedin-learning.png': {
    light: '/images/credentials/linkedin-learning.png',
    dark: '/images/credentials/linkedin-dark.svg'
  },
  '/images/credentials/birzeit.svg': {
    light: '/images/credentials/birzeit.svg',
    dark: '/images/credentials/birzeit-dark.svg'
  }
};

function hasThemeVariants(imagePath: string): boolean {
  return imagePath in themeImages;
}

function getThemeImages(imagePath: string) {
  return themeImages[imagePath] || { light: imagePath, dark: imagePath };
}

function getImageClass(imagePath: string): string {
  return 'w-full h-full object-contain';
}
---

<section id="credentials" class="mb-20 animate-on-scroll">
  <h2 class="text-sm font-medium tracking-widest text-section-heading uppercase mb-8">
    {t(lang, 'credentials.title')}
  </h2>

  <div class="space-y-12">
    <!-- Certifications -->
    <div>
      <h3 class="text-lg font-medium text-foreground mb-6">
        {t(lang, 'credentials.certifications')}
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
        {certifications.map((cert, index) => (
          <div class="animate-on-scroll" style={`animation-delay: ${index * 75}ms`}>
            <div class="flex gap-5">
              <!-- Clickable Image -->
              <button
                type="button"
                class="credential-preview-btn w-20 h-20 rounded-lg overflow-hidden flex-shrink-0 cursor-pointer hover:ring-2 hover:ring-ring transition-all"
                data-image={cert.image}
                data-title={cert.name[lang]}
                aria-label={`View ${cert.name[lang]} certificate`}
              >
                {hasThemeVariants(cert.image) ? (
                  <>
                    <img
                      src={getThemeImages(cert.image).light}
                      alt={cert.issuer[lang]}
                      class={`${getImageClass(cert.image)} dark:hidden`}
                      loading="lazy"
                    />
                    <img
                      src={getThemeImages(cert.image).dark}
                      alt={cert.issuer[lang]}
                      class={`${getImageClass(cert.image)} hidden dark:block`}
                      loading="lazy"
                    />
                  </>
                ) : (
                  <img
                    src={cert.image}
                    alt={cert.issuer[lang]}
                    class={getImageClass(cert.image)}
                    loading="lazy"
                  />
                )}
              </button>
              <!-- Content -->
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-3">
                  <button
                    type="button"
                    class="credential-preview-btn text-base font-medium text-foreground text-start hover:text-muted-foreground transition-colors cursor-pointer"
                    data-image={cert.image}
                    data-title={cert.name[lang]}
                  >
                    {cert.name[lang]}
                  </button>
                  <span class="text-sm text-muted-foreground font-mono flex-shrink-0">
                    {cert.year}
                  </span>
                </div>
                <p class="text-sm text-muted-foreground mt-1">
                  {cert.issuer[lang]}
                </p>
                {cert.url && (
                  <a
                    href={cert.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground mt-2 transition-colors"
                  >
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                      <polyline points="15 3 21 3 21 9"></polyline>
                      <line x1="10" y1="14" x2="21" y2="3"></line>
                    </svg>
                    {lang === 'ar' ? 'عرض الشهادة' : 'View Certificate'}
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div>
      <h3 class="text-lg font-medium text-foreground mb-6">
        {t(lang, 'credentials.education')}
      </h3>
      <div class="divide-y divide-border">
        {education.map((edu, index) => (
          <div class="py-5 first:pt-0 last:pb-0 animate-on-scroll" style={`animation-delay: ${(index + certifications.length) * 75}ms`}>
            <div class="flex gap-5">
              <!-- Clickable Image -->
              <button
                type="button"
                class="credential-preview-btn w-20 h-20 rounded-lg overflow-hidden flex-shrink-0 cursor-pointer hover:ring-2 hover:ring-ring transition-all"
                data-image={edu.image}
                data-title={edu.institution[lang]}
                aria-label={`View ${edu.institution[lang]}`}
              >
                {hasThemeVariants(edu.image) ? (
                  <>
                    <img
                      src={getThemeImages(edu.image).light}
                      alt={edu.institution[lang]}
                      class={`${getImageClass(edu.image)} dark:hidden`}
                      loading="lazy"
                    />
                    <img
                      src={getThemeImages(edu.image).dark}
                      alt={edu.institution[lang]}
                      class={`${getImageClass(edu.image)} hidden dark:block`}
                      loading="lazy"
                    />
                  </>
                ) : (
                  <img
                    src={edu.image}
                    alt={edu.institution[lang]}
                    class={getImageClass(edu.image)}
                    loading="lazy"
                  />
                )}
              </button>
              <!-- Content -->
              <div class="flex-1 min-w-0">
                <button
                  type="button"
                  class="credential-preview-btn text-base font-medium text-foreground text-start hover:text-muted-foreground transition-colors cursor-pointer block"
                  data-image={edu.image}
                  data-title={edu.institution[lang]}
                >
                  {edu.degree[lang]}
                </button>
                <p class="text-sm text-muted-foreground mt-1">
                  {edu.institution[lang]}
                  {edu.field && ` — ${edu.field[lang]}`}
                </p>
                {edu.url && (
                  <a
                    href={edu.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground mt-2 transition-colors"
                  >
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                      <polyline points="15 3 21 3 21 9"></polyline>
                      <line x1="10" y1="14" x2="21" y2="3"></line>
                    </svg>
                    {lang === 'ar' ? 'زيارة الموقع' : 'Visit Website'}
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Lightbox Modal -->
<div
  id="credential-lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center p-6 bg-background/80 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="lightbox-title"
>
  <div class="relative max-w-lg w-full bg-card rounded-xl overflow-hidden shadow-2xl border border-border">
    <!-- Close button -->
    <button
      type="button"
      id="lightbox-close"
      class="absolute top-4 end-4 z-10 p-2 rounded-lg bg-muted/80 text-muted-foreground hover:text-foreground transition-colors"
      aria-label="Close preview"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <!-- Image -->
    <div class="aspect-square bg-muted p-10">
      <img
        id="lightbox-image"
        src=""
        alt=""
        class="w-full h-full object-contain"
      />
    </div>
    <!-- Title -->
    <div class="p-5 border-t border-border">
      <p id="lightbox-title" class="text-center text-base font-medium text-foreground"></p>
    </div>
  </div>
</div>

<script>
  function initCredentialLightbox() {
    const lightbox = document.getElementById('credential-lightbox');
    const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
    const lightboxTitle = document.getElementById('lightbox-title');
    const closeBtn = document.getElementById('lightbox-close');
    const previewBtns = document.querySelectorAll('.credential-preview-btn');

    if (!lightbox || !lightboxImage || !lightboxTitle || !closeBtn) return;

    // Open lightbox
    previewBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const image = btn.getAttribute('data-image');
        const title = btn.getAttribute('data-title');

        if (image && title) {
          lightboxImage.src = image;
          lightboxImage.alt = title;
          lightboxTitle.textContent = title;
          lightbox.classList.remove('hidden');
          lightbox.classList.add('flex');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    // Close lightbox
    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }

    closeBtn.addEventListener('click', closeLightbox);

    // Close on backdrop click
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        closeLightbox();
      }
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) {
        closeLightbox();
      }
    });
  }

  initCredentialLightbox();
  document.addEventListener('astro:after-swap', initCredentialLightbox);
</script>
