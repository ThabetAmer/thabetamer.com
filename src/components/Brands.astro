---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import { brands, type BrandSize } from '../data/brands';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Size/color pairs: larger = more prominent (darker in light mode, brighter in dark mode)
const sizeStyles: Record<BrandSize, { size: string; color: string }> = {
  xs:  { size: 'text-lg md:text-xl', color: 'text-neutral-400 dark:text-neutral-700' },
  sm:  { size: 'text-xl md:text-2xl', color: 'text-neutral-500 dark:text-neutral-600' },
  md:  { size: 'text-2xl md:text-4xl', color: 'text-neutral-600 dark:text-neutral-500' },
  lg:  { size: 'text-4xl md:text-6xl', color: 'text-neutral-700 dark:text-neutral-400' },
  xl:  { size: 'text-5xl md:text-7xl', color: 'text-neutral-800 dark:text-neutral-200' },
  xxl: { size: 'text-6xl md:text-8xl', color: 'text-neutral-900 dark:text-white' },
};

const getStyle = (size: BrandSize) => sizeStyles[size];
---

<section id="brands" class="mb-40 animate-on-scroll">
  <h2 class="text-sm font-medium tracking-widest text-section-heading uppercase mb-8">
    {t(lang, 'brands.title')}
  </h2>

  <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-3 md:gap-x-8 lg:gap-x-12 md:gap-y-4 lg:gap-y-6">
    {brands.map((brand, index) => {
      const style = getStyle(brand.size);
      return (
        <a
          href={brand.url}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            'font-light hover:text-neutral-200 transition-colors duration-200 whitespace-nowrap',
            style.size,
            style.color
          ]}
          style={`--delay: ${index * 50}ms`}
        >
          {brand.name}
        </a>
      );
    })}
  </div>
</section>
