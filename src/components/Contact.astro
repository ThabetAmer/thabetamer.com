---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Actual contact values
const emailUser = 'hello';
const emailDomain = 'thabetamer.com';
const phone = '+1 (302) 469-4950';
const linkedinUrl = 'https://linkedin.com/in/thabetamer';
const githubUrl = 'https://github.com/thabetamer';
const whatsappNumber = '13024694950';

const links = [
  {
    icon: 'phone' as const,
    label: phone,
    href: `https://wa.me/${whatsappNumber}`,
    ariaLabel: 'WhatsApp'
  },
  {
    icon: 'linkedin' as const,
    label: t(lang, 'contact.linkedin'),
    href: linkedinUrl,
    ariaLabel: 'LinkedIn profile'
  },
  {
    icon: 'github' as const,
    label: t(lang, 'contact.github'),
    href: githubUrl,
    ariaLabel: 'GitHub profile'
  }
];
---

<footer id="contact" class="pb-32 pt-16 border-t border-border">
  <h2 class="text-sm font-medium tracking-widest text-section-heading uppercase mb-8">
    {t(lang, 'contact.title')}
  </h2>

  <div class="flex flex-col sm:flex-row flex-wrap gap-x-6 md:gap-x-10 gap-y-4 md:gap-y-5">
    <!-- Email link: obfuscated via JS to prevent scraping -->
    <a
      data-contact-email
      href="#"
      data-u={emailUser}
      data-d={emailDomain}
      class="group flex items-center gap-3 text-muted-foreground hover:text-foreground transition-colors duration-200"
      aria-label="Send email"
    >
      <Icon name="mail" class="w-5 h-5 text-muted-foreground/60 group-hover:text-muted-foreground transition-colors duration-200 flex-shrink-0" />
      <span data-contact-email-label class="text-xs sm:text-sm"></span>
    </a>
    {links.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-3 text-muted-foreground hover:text-foreground transition-colors duration-200"
        aria-label={link.ariaLabel}
      >
        <Icon name={link.icon} class="w-5 h-5 text-muted-foreground/60 group-hover:text-muted-foreground transition-colors duration-200 flex-shrink-0" />
        <span class="text-xs sm:text-sm">{link.label}</span>
      </a>
    ))}
  </div>
</footer>

<script>
  function initContactEmail() {
    document.querySelectorAll('[data-contact-email]').forEach((el) => {
      const anchor = el as HTMLAnchorElement;
      const label = anchor.querySelector('[data-contact-email-label]');
      if (!label) return;
      const email = (anchor.dataset.u ?? '') + '@' + (anchor.dataset.d ?? '');
      anchor.href = 'mailto:' + email;
      label.textContent = email;
    });
  }
  initContactEmail();
  document.addEventListener('astro:after-swap', initContactEmail);
</script>
