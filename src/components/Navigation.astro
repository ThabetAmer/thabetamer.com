---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<nav class="py-6 animate-fade-in-up delay-400">
  <div class="flex flex-wrap justify-between gap-3 md:gap-4 text-xs md:text-sm">
    <a href="#what-i-do" class="py-2 text-muted-foreground hover:text-foreground transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.whatIDo')}
    </a>
    <a href="#portfolio" class="py-2 text-muted-foreground hover:text-foreground transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.portfolio')}
    </a>
    <a href="#credentials" class="py-2 text-muted-foreground hover:text-foreground transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.credentials')}
    </a>
    <a href="#writing" class="py-2 text-muted-foreground hover:text-foreground transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.writing')}
    </a>
    <a href="#contact" class="py-2 text-muted-foreground hover:text-foreground transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.contact')}
    </a>
  </div>
</nav>
