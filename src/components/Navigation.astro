---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<nav class="pt-1 pb-6 animate-fade-in-up delay-400">
  <div class="flex flex-wrap gap-2 md:gap-2.5 text-xs md:text-sm">
    <a href="#services" class="inline-flex flex-1 items-center justify-center rounded-full border border-border px-3.5 py-1.5 text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.services')}
    </a>
    <a href="#portfolio" class="inline-flex flex-1 items-center justify-center rounded-full border border-border px-3.5 py-1.5 text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.portfolio')}
    </a>
    <a href="#credentials" class="inline-flex flex-1 items-center justify-center rounded-full border border-border px-3.5 py-1.5 text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.credentials')}
    </a>
    <a href="#writing" class="inline-flex flex-1 items-center justify-center rounded-full border border-border px-3.5 py-1.5 text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.writing')}
    </a>
    <a href="#contact" class="cta-shine inline-flex flex-1 items-center justify-center rounded-full border border-foreground bg-foreground px-3.5 py-1.5 font-medium text-background hover:bg-foreground/90 transition-colors duration-200 whitespace-nowrap">
      {t(lang, 'nav.contact')}
    </a>
  </div>
</nav>
