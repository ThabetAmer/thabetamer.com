---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';
import Counter from './Counter.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="hero" class="mb-10 pt-8 flex flex-col">
  <!-- Header: Name + Controls -->
  <div class="flex justify-between items-start mb-12">
    <div class="text-xl font-semibold tracking-widest text-foreground uppercase animate-fade-in-up">
      {t(lang, 'hero.name')}
    </div>
    <div class="flex items-center gap-2">
      <LanguageToggle currentLang={lang} />
      <ThemeToggle />
    </div>
  </div>

  <!-- Headline + Profile Image Row -->
  <div class="flex flex-col-reverse md:flex-row items-center gap-8 md:gap-12 mb-6 animate-fade-in-up delay-100">
    <!-- Tagline (main heading) -->
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold text-foreground leading-[1.1] tracking-tight text-center md:text-left">
      {t(lang, 'hero.tagline')}
    </h1>

    <!-- Profile Image -->
    <div class="relative w-48 md:w-64 lg:w-80 shrink-0">
      <img
        src="/images/profile.png"
        alt={t(lang, 'hero.name')}
        class="w-full h-auto object-cover mask-blend dark:invert dark:brightness-50"
      />
    </div>
  </div>

  <!-- Bio -->
  <p class="text-lg md:text-xl text-muted-foreground max-w-2xl leading-relaxed mb-12 animate-fade-in-up delay-200">
    {t(lang, 'hero.bio')}
  </p>

  <!-- Counters -->
  <div class="grid grid-cols-3 gap-8 md:gap-12 mb-4 max-w-2xl">
    <Counter
      value={t(lang, 'hero.counters.experience.value')}
      label={t(lang, 'hero.counters.experience.label')}
    />
    <Counter
      value={t(lang, 'hero.counters.countries.value')}
      label={t(lang, 'hero.counters.countries.label')}
    />
    <Counter
      value={t(lang, 'hero.counters.projects.value')}
      label={t(lang, 'hero.counters.projects.label')}
    />
  </div>


</section>
