---
// ScrollToTop button component - appears when user scrolls down
// Choose from these creative minimal arrow designs by changing the SVG content
---

<button
  id="scroll-to-top"
  class="fixed bottom-8 right-8 p-3 rounded-full bg-primary text-primary-foreground opacity-0 pointer-events-none transition-opacity duration-300 hover:scale-110 cursor-pointer z-40"
  aria-label="Scroll to top"
>
  <svg
    class="w-4 h-4"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <!-- Option 1: Stacked horizontal lines getting smaller (pyramid) -->
    <line x1="6" y1="16" x2="18" y2="16" stroke-width="2" stroke-linecap="round" />
    <line x1="8" y1="12" x2="16" y2="12" stroke-width="2" stroke-linecap="round" />
    <line x1="10" y1="8" x2="14" y2="8" stroke-width="2" stroke-linecap="round" />
  </svg>
</button>

<!-- Alternative designs you can swap in: -->

