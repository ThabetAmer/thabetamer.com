---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import type { WorkItem } from '../data/work';
import Icon from './Icon.astro';

interface Props {
  project: WorkItem;
  lang: Lang;
  index?: number;
}

const { project, lang, index = 0 } = Astro.props;

const tagLabels: Record<string, Record<Lang, string>> = {
  product: { en: 'Product', ar: 'منتج' },
  architecture: { en: 'Architecture', ar: 'هندسة' },
  cloud: { en: 'Cloud', ar: 'سحابة' },
  ai: { en: 'AI', ar: 'ذكاء اصطناعي' },
  gov: { en: 'Gov/NGO', ar: 'حكومي' },
  startups: { en: 'Startup', ar: 'ناشئة' }
};
---

<article
  class="project-card group rounded-xl border border-border bg-secondary/50 overflow-hidden transition-all duration-300 ease-out hover:border-muted-foreground/50 cursor-pointer"
  data-tags={project.tags.join(',')}
  data-project-id={project.id}
  data-title={project.title[lang]}
  data-client={project.client[lang]}
  data-role={project.role[lang]}
  data-year={project.year}
  data-description={project.description[lang]}
  data-details={project.details?.[lang] || ''}
  data-image={project.image}
  data-tags-display={project.tags.map(tag => tagLabels[tag]?.[lang] || tag).join(', ')}
  style={`animation-delay: ${index * 75}ms`}
>
  <!-- Project Image with grayscale effect -->
  <div class="aspect-video bg-background overflow-hidden">
    <img
      src={project.image}
      alt={project.title[lang]}
      class="w-full h-full object-cover img-grayscale hover-scale"
      loading="lazy"
    />
  </div>

  <!-- Content -->
  <div class="p-6">
    <div class="flex items-start justify-between gap-3 mb-3">
      <h3 class="text-lg font-medium text-foreground group-hover:text-foreground/90 transition-colors">
        {project.title[lang]}
      </h3>
      <Icon name="arrow-up-right" class="w-5 h-5 text-muted-foreground opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex-shrink-0" />
    </div>

    <p class="text-sm text-muted-foreground mb-3">
      {project.client[lang]} &middot; {project.year}
    </p>

    <span class="inline-block px-3 py-1 text-sm font-medium rounded-full bg-muted text-muted-foreground mb-4">
      {project.role[lang]}
    </span>

    <p class="text-base text-muted-foreground leading-relaxed mb-4">
      {project.description[lang]}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2">
      {project.tags.map(tag => (
        <span class="px-2.5 py-1 text-sm rounded-full border border-border text-muted-foreground">
          {tagLabels[tag]?.[lang] || tag}
        </span>
      ))}
    </div>
  </div>
</article>
