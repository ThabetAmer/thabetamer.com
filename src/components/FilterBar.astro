---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import { getAllPortfolioTags, type ProjectTag } from '../data/work';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tags = getAllPortfolioTags();

const tagLabels: Record<ProjectTag, string> = {
  product: t(lang, 'portfolio.filters.product'),
  architecture: t(lang, 'portfolio.filters.architecture'),
  cloud: t(lang, 'portfolio.filters.cloud'),
  ai: t(lang, 'portfolio.filters.ai'),
  gov: t(lang, 'portfolio.filters.gov'),
  startups: t(lang, 'portfolio.filters.startups'),
  devops: 'DevOps',
  saas: 'SaaS',
  edtech: 'EdTech',
  ict4d: 'ICT4D',
  agritech: 'AgriTech'
};
---

<div class="flex flex-wrap gap-3" role="tablist" aria-label="Filter projects">
  {tags.map((tag, index) => (
    <button
      type="button"
      role="tab"
      aria-selected={index === 0 ? 'true' : 'false'}
      data-filter={tag}
      class:list={[
        'filter-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 ease-out',
        'border',
        index === 0
          ? 'bg-foreground text-background border-foreground'
          : 'bg-transparent text-muted-foreground border-border hover:border-foreground hover:text-foreground hover:bg-muted'
      ]}
    >
      {tagLabels[tag]}
    </button>
  ))}
</div>

<script>
  let _filterCleanups: (() => void)[] = [];
  const _hideTimeouts = new Map<string, number>();

  function initFilters() {
    _filterCleanups.forEach(fn => fn());
    _filterCleanups = [];
    _hideTimeouts.forEach(id => clearTimeout(id));
    _hideTimeouts.clear();

    const pills = document.querySelectorAll('.filter-pill');
    const cards = document.querySelectorAll('.project-card');

    // Apply initial filter (first tag)
    const firstPill = pills[0];
    if (firstPill) {
      const initialTag = firstPill.getAttribute('data-filter');
      filterCards(initialTag, cards, true);
    }

    pills.forEach(pill => {
      const handleClick = () => {
        const tag = pill.getAttribute('data-filter');

        // Update active pill styling
        pills.forEach(p => {
          p.classList.remove('bg-foreground', 'text-background', 'border-foreground');
          p.classList.add('bg-transparent', 'text-muted-foreground', 'border-border');
          p.setAttribute('aria-selected', 'false');
        });
        pill.classList.remove('bg-transparent', 'text-muted-foreground', 'border-border');
        pill.classList.add('bg-foreground', 'text-background', 'border-foreground');
        pill.setAttribute('aria-selected', 'true');

        filterCards(tag, cards, false);
      };
      pill.addEventListener('click', handleClick);
      _filterCleanups.push(() => pill.removeEventListener('click', handleClick));
    });
  }

  function filterCards(tag: string | null, cards: NodeListOf<Element>, immediate: boolean) {
    // Clear any pending hide timeouts to prevent race conditions
    _hideTimeouts.forEach(id => clearTimeout(id));
    _hideTimeouts.clear();

    let visibleIndex = 0;
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const cardId = el.getAttribute('data-project-id') || '';
      const cardTags = el.getAttribute('data-tags')?.split(',') || [];
      const shouldShow = cardTags.includes(tag || '');

      if (shouldShow) {
        if (immediate) {
          el.style.display = 'block';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        } else {
          const delay = visibleIndex * 75;
          el.style.display = 'block';
          requestAnimationFrame(() => {
            setTimeout(() => {
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, delay);
          });
        }
        visibleIndex++;
      } else {
        if (immediate) {
          el.style.display = 'none';
          el.style.opacity = '0';
          el.style.transform = 'translateY(8px)';
        } else {
          el.style.opacity = '0';
          el.style.transform = 'translateY(8px)';
          const timeoutId = setTimeout(() => {
            el.style.display = 'none';
            _hideTimeouts.delete(cardId);
          }, 300) as unknown as number;
          _hideTimeouts.set(cardId, timeoutId);
        }
      }
    });
  }

  initFilters();
  document.addEventListener('astro:after-swap', initFilters);
</script>
